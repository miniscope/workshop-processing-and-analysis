# Data: never commit recordings or intermediates — fetched by scripts/get_data.py.
data/sessions/
data/.cache/

# Minian dask scratch (intpath / MINIAN_INTERMEDIATE) — regenerated each run.
minian_intermediate/

# CaMAP capstone output bundles — written by ds.save_bundle(), regenerated each run.
capstone/output/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
build/
dist/

# Jupyter
.ipynb_checkpoints/

# Teaching notebooks fetched from the installed tools (version-matched, generated
# by scripts/fetch_notebooks.py — not vendored). The capstone notebook lives in
# capstone/ and IS committed.
tutorials/*/notebooks/

# OS / editor
.DS_Store
.vscode/
.idea/
